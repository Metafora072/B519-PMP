[Unit]
Description=B519-PMP Next.js Web
Requires=b519-pmp-prepare.service
After=b519-pmp-prepare.service network-online.target
Wants=network-online.target
PartOf=b519-pmp.service

[Service]
Type=simple
User=__RUN_USER__
Group=__RUN_GROUP__
WorkingDirectory=__PROJECT_ROOT__/web
Environment=NODE_ENV=production
Environment=NEXT_TELEMETRY_DISABLED=1
Environment=HOST=0.0.0.0
Environment=PORT=3000
EnvironmentFile=-__PROJECT_ROOT__/.env.systemd
ExecStart=/usr/bin/env bash __PROJECT_ROOT__/scripts/systemd/run-web.sh
Restart=on-failure
RestartSec=5
TimeoutStopSec=30
