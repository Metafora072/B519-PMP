generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum ProjectStatus {
  ACTIVE
  ARCHIVED
}

enum ProjectVisibility {
  PRIVATE
  MEMBERS_VISIBLE
  ORG_VISIBLE
}

enum JoinPolicy {
  INVITE_ONLY
  REQUEST_APPROVAL
  OPEN
}

enum ProjectRole {
  OWNER
  ADMIN
  MEMBER
  GUEST
}

enum ProjectMemberStatus {
  ACTIVE
  INVITED
  PENDING
}

enum TaskType {
  REQUIREMENT
  BUG
  IMPROVEMENT
  TECH_DEBT
  RESEARCH
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CLOSED
}

enum TaskPriority {
  P0
  P1
  P2
  P3
}

enum NotificationType {
  TASK_ASSIGNED
  TASK_REASSIGNED
  COMMENT_MENTION
  PROJECT_JOIN_REQUEST
  PROJECT_JOIN_APPROVED
  PROJECT_JOIN_REJECTED
  PROJECT_INVITED
  TASK_OVERDUE
}

model User {
  id                      BigInt          @id @default(autoincrement())
  email                   String          @unique @db.VarChar(255)
  passwordHash            String          @map("password_hash") @db.VarChar(255)
  name                    String          @db.VarChar(100)
  avatarUrl               String?         @map("avatar_url") @db.VarChar(500)
  status                  UserStatus      @default(ACTIVE)
  createdAt               DateTime        @default(now()) @map("created_at")
  updatedAt               DateTime        @updatedAt @map("updated_at")
  ownedProjects           Project[]       @relation("ProjectOwner")
  projectMembers          ProjectMember[]
  sentProjectInvitations  ProjectMember[] @relation("ProjectMemberInviter")
  approvedProjectMembers  ProjectMember[] @relation("ProjectMemberApprover")
  ownedModules            Module[]
  createdTasks            Task[]          @relation("TaskCreator")
  assignedTasks           Task[]          @relation("TaskAssignee")
  taskComments            TaskComment[]
  activityLogs            TaskActivityLog[]
  notifications           Notification[]  @relation("NotificationRecipient")
  actedNotifications      Notification[]  @relation("NotificationActor")

  @@map("users")
}

model Project {
  id              BigInt            @id @default(autoincrement())
  name            String            @db.VarChar(120)
  projectKey      String            @unique @map("project_key") @db.VarChar(30)
  description     String?           @db.Text
  icon            String?           @db.VarChar(255)
  status          ProjectStatus     @default(ACTIVE)
  visibility      ProjectVisibility @default(PRIVATE)
  joinPolicy      JoinPolicy        @default(INVITE_ONLY) @map("join_policy")
  ownerId         BigInt            @map("owner_id")
  memberColorSeed String?           @map("member_color_seed") @db.VarChar(60)
  taskSeq         Int               @default(0) @map("task_seq")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  owner           User              @relation("ProjectOwner", fields: [ownerId], references: [id])
  members         ProjectMember[]
  modules         Module[]
  tasks           Task[]
  labels          Label[]
  activityLogs    TaskActivityLog[]
  notifications   Notification[]

  @@map("projects")
}

model ProjectMember {
  id                BigInt              @id @default(autoincrement())
  projectId         BigInt              @map("project_id")
  userId            BigInt              @map("user_id")
  role              ProjectRole
  status            ProjectMemberStatus @default(ACTIVE)
  joinedAt          DateTime?           @map("joined_at")
  invitedBy         BigInt?             @map("invited_by")
  approvedBy        BigInt?             @map("approved_by")
  displayColorToken String?             @map("display_color_token") @db.VarChar(30)
  createdAt         DateTime            @default(now()) @map("created_at")
  project           Project             @relation(fields: [projectId], references: [id])
  user              User                @relation(fields: [userId], references: [id])
  inviter           User?               @relation("ProjectMemberInviter", fields: [invitedBy], references: [id])
  approver          User?               @relation("ProjectMemberApprover", fields: [approvedBy], references: [id])

  @@unique([projectId, userId])
  @@index([projectId, status])
  @@index([userId, status])
  @@map("project_members")
}

model Module {
  id          BigInt    @id @default(autoincrement())
  projectId   BigInt    @map("project_id")
  name        String    @db.VarChar(120)
  description String?   @db.Text
  ownerId     BigInt    @map("owner_id")
  color       String?   @db.VarChar(30)
  sortOrder   Int       @default(0) @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  project     Project   @relation(fields: [projectId], references: [id])
  owner       User      @relation(fields: [ownerId], references: [id])
  tasks       Task[]

  @@unique([projectId, name])
  @@map("modules")
}

model Task {
  id              BigInt             @id @default(autoincrement())
  projectId       BigInt             @map("project_id")
  moduleId        BigInt?            @map("module_id")
  taskNo          String             @map("task_no") @db.VarChar(50)
  parentTaskId    BigInt?            @map("parent_task_id")
  title           String             @db.VarChar(255)
  description     String?            @db.Text
  type            TaskType           @default(REQUIREMENT)
  status          TaskStatus         @default(TODO)
  priority        TaskPriority       @default(P2)
  creatorId       BigInt             @map("creator_id")
  assigneeId      BigInt?            @map("assignee_id")
  dueAt           DateTime?          @map("due_at")
  startAt         DateTime?          @map("start_at")
  completedAt     DateTime?          @map("completed_at")
  repoName        String?            @map("repo_name") @db.VarChar(255)
  branchName      String?            @map("branch_name") @db.VarChar(255)
  prUrl           String?            @map("pr_url") @db.VarChar(500)
  issueUrl        String?            @map("issue_url") @db.VarChar(500)
  estimateHours   Int?               @map("estimate_hours")
  deletedAt       DateTime?          @map("deleted_at")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")
  project         Project            @relation(fields: [projectId], references: [id])
  module          Module?            @relation(fields: [moduleId], references: [id])
  creator         User               @relation("TaskCreator", fields: [creatorId], references: [id])
  assignee        User?              @relation("TaskAssignee", fields: [assigneeId], references: [id])
  parentTask      Task?              @relation("TaskHierarchy", fields: [parentTaskId], references: [id])
  childTasks      Task[]             @relation("TaskHierarchy")
  comments        TaskComment[]
  activityLogs    TaskActivityLog[]
  taskLabels      TaskLabel[]
  notifications   Notification[]

  @@unique([projectId, taskNo])
  @@map("tasks")
}

model TaskComment {
  id        BigInt   @id @default(autoincrement())
  taskId    BigInt   @map("task_id")
  userId    BigInt   @map("user_id")
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  task      Task     @relation(fields: [taskId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@index([taskId, createdAt])
  @@map("task_comments")
}

model TaskActivityLog {
  id           BigInt   @id @default(autoincrement())
  projectId    BigInt   @map("project_id")
  taskId       BigInt   @map("task_id")
  operatorId   BigInt   @map("operator_id")
  actionType   String   @map("action_type") @db.VarChar(100)
  actionDetail Json?    @map("action_detail")
  createdAt    DateTime @default(now()) @map("created_at")
  project      Project  @relation(fields: [projectId], references: [id])
  task         Task     @relation(fields: [taskId], references: [id])
  operator     User     @relation(fields: [operatorId], references: [id])

  @@index([taskId, createdAt])
  @@index([projectId, createdAt])
  @@map("task_activity_logs")
}

model Label {
  id        BigInt      @id @default(autoincrement())
  projectId BigInt      @map("project_id")
  name      String      @db.VarChar(50)
  color     String      @db.VarChar(30)
  createdAt DateTime    @default(now()) @map("created_at")
  project   Project     @relation(fields: [projectId], references: [id])
  taskLabels TaskLabel[]

  @@unique([projectId, name])
  @@map("labels")
}

model TaskLabel {
  id      BigInt @id @default(autoincrement())
  taskId  BigInt @map("task_id")
  labelId BigInt @map("label_id")
  task    Task   @relation(fields: [taskId], references: [id])
  label   Label  @relation(fields: [labelId], references: [id])

  @@unique([taskId, labelId])
  @@map("task_labels")
}

model Notification {
  id               BigInt           @id @default(autoincrement())
  userId           BigInt           @map("user_id")
  type             NotificationType
  title            String           @db.VarChar(255)
  content          String?          @db.Text
  relatedProjectId BigInt?          @map("related_project_id")
  relatedTaskId    BigInt?          @map("related_task_id")
  actorId          BigInt?          @map("actor_id")
  isRead           Boolean          @default(false) @map("is_read")
  metadataJson     Json?            @map("metadata_json")
  createdAt        DateTime         @default(now()) @map("created_at")
  user             User             @relation("NotificationRecipient", fields: [userId], references: [id])
  actor            User?            @relation("NotificationActor", fields: [actorId], references: [id])
  project          Project?         @relation(fields: [relatedProjectId], references: [id])
  task             Task?            @relation(fields: [relatedTaskId], references: [id])

  @@index([userId, isRead, createdAt])
  @@index([userId, type, createdAt])
  @@index([relatedProjectId])
  @@index([relatedTaskId])
  @@map("notifications")
}
